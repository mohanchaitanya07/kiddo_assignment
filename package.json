{
  "name": "kiddo",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@shopify/flash-list": "2.0.2",
    "expo": "~55.0.26",
    "expo-status-bar": "~55.0.6",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.18",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
